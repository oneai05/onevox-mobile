# OneVox - variaveis de ambiente (EXEMPLO)
# Copie para .env e preencha. O .env real NUNCA vai para o git.
# As chaves de producao ficam no painel da Vercel (Environment Variables),
# nunca em arquivo versionado.

# --- Backend (Vercel Functions) - SECRETO, nunca expor no frontend ---
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# STT (se usar provedor pago)
ASSEMBLYAI_API_KEY=

# --- Frontend (publico por design - protegido por RLS) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- App ---
CORS_ORIGIN=https://onevox.example.com
